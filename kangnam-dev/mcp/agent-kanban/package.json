{
  "name": "kanban-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Project-local developer Kanban with a token-efficient CLI, human UI, and optional MCP adapter.",
  "bin": {
    "agent-kanban": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"tsx watch src/server/api.ts\" \"vite --host 127.0.0.1 --port 3001\"",
    "dev:api": "tsx watch src/server/api.ts",
    "dev:web": "vite --host 127.0.0.1 --port 3001",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/index.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "cli": "node dist/cli/index.js",
    "start": "node dist/server/api.js",
    "mcp": "node dist/mcp/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "express": "^4.18.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
